<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.ahmadre.hinata</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>hinata</string>
			</array>
		</dict>
	</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<!-- Let app_links be the single deep-link handler. Otherwise Flutter's
		     built-in deep linking also routes the raw hinata://auth-callback URI
		     into go_router, which can't match it ("Page Not Found"). -->
		<key>FlutterDeepLinkingEnabled</key>
		<false/>
		<!-- Export compliance: Hinata only uses standard, exempt encryption (HTTPS/TLS
		     via the OS). Declaring this auto-clears every TestFlight/App Store build so
		     reviewers aren't prompted for the encryption questionnaire each upload. -->
		<key>ITSAppUsesNonExemptEncryption</key>
		<false/>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Hinata</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>hinata</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UIApplicationSceneManifest</key>
		<dict>
			<key>UIApplicationSupportsMultipleScenes</key>
			<false/>
			<key>UISceneConfigurations</key>
			<dict>
				<key>UIWindowSceneSessionRoleApplication</key>
				<array>
					<dict>
						<key>UISceneClassName</key>
						<string>UIWindowScene</string>
						<key>UISceneConfigurationName</key>
						<string>flutter</string>
						<key>UISceneDelegateClassName</key>
						<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
						<key>UISceneStoryboardFile</key>
						<string>Main</string>
					</dict>
				</array>
			</dict>
		</dict>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<!-- Allow FCM/APNs to wake the app for background data messages. -->
		<key>UIBackgroundModes</key>
		<array>
			<string>remote-notification</string>
		</array>
		<key>UIAppFonts</key>
		<array>
			<string>Sora-Variable.ttf</string>
		</array>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UIStatusBarHidden</key>
		<false/>
		<key>NSPhotoLibraryUsageDescription</key>
		<string>Hinata needs access to your photo library so you can attach photos and videos to issues.</string>
		<key>NSCameraUsageDescription</key>
		<string>Hinata needs access to your camera so you can take a photo or record a video to attach to issues.</string>
		<key>NSMicrophoneUsageDescription</key>
		<string>Hinata needs access to your microphone so videos you record for issue attachments include sound.</string>
		<!-- Required by Apple (ITMS-90683): the media picker (file_picker →
		     DKImagePickerController) references PHAsset.location, i.e. the GPS
		     metadata stored inside photos/videos. Hinata never tracks your device
		     location and never prompts for it; this string only covers location
		     data already embedded in files you choose to attach. -->
		<key>NSLocationWhenInUseUsageDescription</key>
		<string>Hinata does not track your location. This is only needed so photos or videos you choose to attach to issues keep the location information already saved inside them.</string>
	</dict>
</plist>
