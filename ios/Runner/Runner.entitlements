<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push notifications (FCM/APNs). The value must match the signing profile's
	     aps-environment. CI archives are signed with the App Store distribution
	     profile (aps-environment = production), so this is "production". For local
	     on-device debug push you'd temporarily switch this to "development". -->
	<key>aps-environment</key>
	<string>production</string>
	<!-- Universal Links (Option B): lets verified https links from the production
	     web domain open the app. Apple fetches
	     https://track.asta.hn/.well-known/apple-app-site-association and matches
	     it against this app's appID (T852K29HWS.com.ahmadre.hinata).
	     NOTE: the matching provisioning profile must have the Associated Domains
	     capability enabled (Apple Developer portal / fastlane match). -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<!-- Hinata Connect relay: the ONE verified domain for the white-label app,
		     so invite/reset links from ANY self-hosted server open this app
		     (https://connect.track.asta.hn/.well-known/apple-app-site-association). -->
		<string>applinks:connect.track.asta.hn</string>
		<!-- Direct links for the AStA instance's own web domain. -->
		<string>applinks:track.asta.hn</string>
	</array>
</dict>
</plist>
