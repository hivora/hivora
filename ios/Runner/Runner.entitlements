<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push notifications (FCM/APNs). The value must match the signing profile's
	     aps-environment. CI archives are signed with the App Store distribution
	     profile (aps-environment = production), so this is "production". For local
	     on-device debug push you'd temporarily switch this to "development". -->
	<key>aps-environment</key>
	<string>production</string>
	<!-- Hinata Connect relay: the ONE verified domain for the white-label app, so
	     invite/reset links from ANY self-hosted server open this app. Apple fetches
	     https://connect.hinata.ahmadre.com/.well-known/apple-app-site-association and
	     matches it against this app's appID. The matching provisioning profile must
	     have the Associated Domains capability enabled (fastlane match). -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:connect.hinata.ahmadre.com</string>
	</array>
</dict>
</plist>
