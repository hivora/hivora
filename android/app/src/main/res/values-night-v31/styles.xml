<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting (Dark Mode) -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowSplashScreenBackground">#131119</item>
        <!-- Hinata: animiertes Logo statt statischem Icon (Night-Variante in Hellblau) -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/hinata_splash_animated</item>
        <item name="android:windowSplashScreenAnimationDuration">1200</item>
    </style>
    <!-- Theme applied to the Android Window as soon as the process has started. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
